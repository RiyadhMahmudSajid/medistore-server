{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",             
    "moduleResolution": "NodeNext",   
    "outDir": "./dist",
     "rootDir": "./",                 
    
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "isolatedModules": true,
    "moduleDetection": "force"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "generated/prisma"]
}